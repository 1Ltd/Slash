<resources>

    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/colorPrimaryContainer</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher</item>
        <item name="windowSplashScreenAnimationDuration">300</item>
        <item name="postSplashScreenTheme">@style/AppTheme</item>
    </style>

    <!-- Base Material3 DayNight theme with Seal color tokens -->
    <style name="Base.AppTheme" parent="Theme.Material3.DayNight">
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightNavigationBar">true</item>

        <!-- M3 color roles mapped to Seal green palette -->
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorOnPrimary">@color/colorOnPrimary</item>
        <item name="colorPrimaryContainer">@color/colorPrimaryContainer</item>
        <item name="colorOnPrimaryContainer">@color/colorOnPrimaryContainer</item>
        <item name="colorSecondary">@color/colorAccent</item>
        <item name="colorSecondaryContainer">@color/colorSecondaryContainer</item>
        <item name="colorTertiary">@color/colorTertiary</item>
        <item name="colorTertiaryContainer">@color/colorTertiaryContainer</item>
        <item name="colorSurface">@color/colorSurface</item>
        <item name="colorSurfaceVariant">@color/colorSurfaceVariant</item>
        <item name="colorOnSurface">@color/colorOnSurface</item>
        <item name="colorOnSurfaceVariant">@color/colorOnSurfaceVariant</item>
        <item name="colorOutline">@color/colorOutline</item>
        <item name="android:colorBackground">@color/colorBackground</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>

        <!-- Shape tokens for Seal-like rounded cards -->
        <item name="shapeAppearanceSmallComponent">@style/ShapeAppearance.App.SmallComponent</item>
        <item name="shapeAppearanceMediumComponent">@style/ShapeAppearance.App.MediumComponent</item>
        <item name="shapeAppearanceLargeComponent">@style/ShapeAppearance.App.LargeComponent</item>

        <!-- Bottom navigation bar style -->
        <item name="bottomNavigationStyle">@style/Widget.App.BottomNavigationView</item>

        <!-- Toolbar style -->
        <item name="toolbarStyle">@style/Widget.App.Toolbar</item>
        <item name="materialToolbarStyle">@style/Widget.App.Toolbar</item>

        <!-- Card style -->
        <item name="materialCardViewStyle">@style/Widget.App.CardView</item>

        <!-- FAB style -->
        <item name="floatingActionButtonStyle">@style/Widget.App.FloatingActionButton</item>

        <!-- Switch -->
        <item name="switchStyle">@style/Widget.App.Switch</item>
    </style>

    <style name="AppTheme" parent="Base.AppTheme">
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <style name="AppTheme.Launcher">
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowActionBar">false</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowContentOverlay">@null</item>
    </style>

    <!-- Shape appearances matching Seal's rounded corners -->
    <style name="ShapeAppearance.App.SmallComponent" parent="ShapeAppearance.Material3.SmallComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">12dp</item>
    </style>
    <style name="ShapeAppearance.App.MediumComponent" parent="ShapeAppearance.Material3.MediumComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">16dp</item>
    </style>
    <style name="ShapeAppearance.App.LargeComponent" parent="ShapeAppearance.Material3.LargeComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">24dp</item>
    </style>

    <!-- Cards: elevated, no stroke, 16dp radius -->
    <style name="Widget.App.CardView" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">2dp</item>
        <item name="strokeWidth">0dp</item>
    </style>

    <!-- Bottom nav: pill indicator, no labels hidden -->
    <style name="Widget.App.BottomNavigationView" parent="Widget.Material3.BottomNavigationView">
        <item name="labelVisibilityMode">labeled</item>
        <item name="itemRippleColor">@color/colorPrimaryContainer</item>
        <item name="itemPaddingTop">8dp</item>
        <item name="itemPaddingBottom">8dp</item>
    </style>

    <!-- Toolbar: clean white/surface, no elevation -->
    <style name="Widget.App.Toolbar" parent="Widget.Material3.Toolbar">
        <item name="android:elevation">0dp</item>
        <item name="navigationIconTint">?colorOnSurface</item>
    </style>

    <!-- FAB: filled tonal, green -->
    <style name="Widget.App.FloatingActionButton" parent="Widget.Material3.FloatingActionButton.Primary">
        <item name="backgroundTint">@color/colorPrimaryContainer</item>
        <item name="tint">@color/colorOnPrimaryContainer</item>
    </style>

    <!-- Switch: Material3 -->
    <style name="Widget.App.Switch" parent="Widget.Material3.CompoundButton.MaterialSwitch" />

    <!-- Seek bar -->
    <style name="MySeekBar" parent="Widget.AppCompat.SeekBar">
        <item name="colorControlNormal">@color/colorPrimary</item>
        <item name="colorControlHighlight">@color/colorPrimaryContainer</item>
    </style>

    <!-- Image view shape overlays -->
    <style name="customImageViewRounded" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">12dp</item>
    </style>
    <style name="ShapeAppearanceOverlay.Rounded" parent="">
        <item name="cornerSize">50%</item>
    </style>
    <style name="ShapeAppearanceOverlay.App.rounded" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">8dp</item>
    </style>

    <!-- Switch selector colors (legacy compat) -->
    <style name="SwitchThumbSelector" parent="">
        <item name="android:state_checked">@color/colorPrimary</item>
    </style>

    <!-- Settings section header -->
    <style name="TextAppearance.App.SectionHeader" parent="TextAppearance.Material3.LabelLarge">
        <item name="android:textColor">?colorPrimary</item>
        <item name="android:paddingTop">20dp</item>
        <item name="android:paddingBottom">4dp</item>
    </style>

</resources>
