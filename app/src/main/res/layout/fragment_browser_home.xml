<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>
        <import type="android.view.View" />
        <variable name="browserMenuListener" type="com.myAllVideoBrowser.ui.main.home.browser.BrowserListener" />
        <variable name="viewModel" type="com.myAllVideoBrowser.ui.main.home.browser.homeTab.BrowserHomeViewModel" />
        <variable name="mainVModel" type="com.myAllVideoBrowser.ui.main.home.MainViewModel" />
    </data>

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="?android:attr/colorBackground">

        <!-- Top bar with menu button (no title, Seal style) -->
        <com.google.android.material.appbar.AppBarLayout
            android:id="@id/appBarLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="?colorSurface"
            app:elevation="0dp">

            <com.google.android.material.appbar.MaterialToolbar
                android:id="@+id/materialToolbar"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/browser_home_menu_button"
                    style="?attr/materialIconButtonStyle"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_gravity="end"
                    android:onClick="@{() -> browserMenuListener.onBrowserMenuClicked()}"
                    app:icon="@drawable/ic_more_24dp"
                    app:iconTint="?colorOnSurface" />
            </com.google.android.material.appbar.MaterialToolbar>
        </com.google.android.material.appbar.AppBarLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingTop="?attr/actionBarSize"
            android:paddingHorizontal="24dp"
            app:layout_behavior="@string/appbar_scrolling_view_behavior">

            <!-- Seal-style search bar: outlined, rounded, elevated -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="8dp"
                app:cardBackgroundColor="?colorSurfaceVariant"
                app:cardCornerRadius="28dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

                <com.google.android.material.textfield.MaterialAutoCompleteTextView
                    android:id="@+id/home_et_search"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@null"
                    android:drawableStart="@drawable/search_24px"
                    android:drawablePadding="12dp"
                    android:focusable="@{viewModel.isSearchInputFocused}"
                    android:focusableInTouchMode="@{viewModel.isSearchInputFocused}"
                    android:gravity="center_vertical"
                    android:hint="@string/browser_search_hint"
                    android:onClick="@{() -> viewModel.changeSearchFocus(true)}"
                    android:paddingHorizontal="20dp"
                    android:singleLine="true"
                    android:text="@{viewModel.searchTextInput}"
                    android:textAppearance="?textAppearanceBodyLarge"
                    app:items="@{viewModel.listSuggestions}" />
            </com.google.android.material.card.MaterialCardView>

            <!-- Go button (filled pill) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/go_button"
                android:layout_width="160dp"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:text="@string/go"
                app:shapeAppearance="@style/ShapeAppearance.App.LargeComponent" />

            <!-- Quick access grid -->
            <GridView
                android:id="@+id/top_pages_grid"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="24dp"
                android:layout_weight="1"
                android:gravity="center"
                android:horizontalSpacing="8dp"
                android:numColumns="4"
                android:paddingHorizontal="4dp"
                android:verticalSpacing="8dp"
                app:items="@{mainVModel.bookmarksList}" />

        </LinearLayout>
    </androidx.coordinatorlayout.widget.CoordinatorLayout>
</layout>
