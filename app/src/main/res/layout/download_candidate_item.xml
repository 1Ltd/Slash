<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>
        <import type="android.view.View" />
        <variable name="listener" type="com.myAllVideoBrowser.ui.component.adapter.CandidateFormatListener" />
        <variable name="download_candidate" type="String" />
        <variable name="is_candidate_selected" type="Boolean" />
        <variable name="videoInfo" type="com.myAllVideoBrowser.data.local.room.entity.VideoInfo" />
    </data>

    <!-- Seal-style format chip: tonal card, selected = primaryContainer + stroke -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_item"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="4dp"
        android:checkable="true"
        android:checked="@{is_candidate_selected}"
        android:onClick="@{() -> listener.onSelectFormat(videoInfo, download_candidate)}"
        android:onLongClick="@{() -> listener.onFormatUrlShare(videoInfo, download_candidate)}"
        app:cardBackgroundColor="@{is_candidate_selected ? @color/colorPrimaryContainer : @color/colorSurface}"
        app:cardCornerRadius="20dp"
        app:cardElevation="@{is_candidate_selected ? 3f : 1f}"
        app:strokeColor="@{is_candidate_selected ? @color/colorPrimary : @android:color/transparent}"
        app:strokeWidth="2dp"
        tools:checked="false">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:minWidth="72dp"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingVertical="12dp">

            <!-- Resolution / quality label (big) -->
            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/tv_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="@string/player_resolution"
                android:textAppearance="?textAppearanceTitleMedium"
                android:textColor="@{is_candidate_selected ? @color/colorOnPrimaryContainer : @color/colorOnSurface}" />

            <!-- File size / format info -->
            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/tv_data"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:layout_marginTop="2dp"
                android:text="@string/player_resolution"
                android:textAppearance="?textAppearanceLabelSmall"
                android:textColor="@{is_candidate_selected ? @color/colorOnPrimaryContainer : @color/colorOnSurfaceVariant}" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
</layout>
