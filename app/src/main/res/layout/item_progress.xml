<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>
        <import type="android.view.View" />
        <variable name="progressInfo" type="com.myAllVideoBrowser.data.local.room.entity.ProgressInfo" />
        <variable name="downloadId" type="Long" />
        <variable name="isRegular" type="Boolean" />
        <variable name="progressListener" type="com.myAllVideoBrowser.ui.component.adapter.ProgressListener" />
    </data>

    <!-- Seal-style: ElevatedCard, thumbnail left, animated progress bar, status chip -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_progress"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginVertical="6dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="2dp"
        app:strokeWidth="0dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="12dp">

            <!-- Thumbnail with rounded corners -->
            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/iv_thumbnail"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:scaleType="centerCrop"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:shapeAppearanceOverlay="@style/customImageViewRounded" />

            <!-- Title -->
            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/tv_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="4dp"
                android:maxLines="2"
                android:text="@{progressInfo.videoInfo.name}"
                android:textAppearance="?textAppearanceTitleSmall"
                app:layout_constraintEnd_toStartOf="@+id/ip_more"
                app:layout_constraintStart_toEndOf="@+id/iv_thumbnail"
                app:layout_constraintTop_toTopOf="@+id/iv_thumbnail"
                tools:text="Video Title Goes Here" />

            <!-- Progress size label -->
            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/tv_progress"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_marginTop="4dp"
                android:maxLines="1"
                android:text="@{progressInfo.progressSize}"
                android:textAppearance="?textAppearanceBodySmall"
                android:textColor="?colorOnSurfaceVariant"
                app:layout_constraintEnd_toStartOf="@+id/ip_more"
                app:layout_constraintStart_toEndOf="@+id/iv_thumbnail"
                app:layout_constraintTop_toBottomOf="@+id/tv_title"
                tools:text="4.5 MB / 48 MB" />

            <!-- Animated linear progress indicator -->
            <com.google.android.material.progressindicator.LinearProgressIndicator
                android:id="@+id/progress_bar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_marginTop="6dp"
                android:progress="@{progressInfo.progress}"
                app:indicatorColor="?colorPrimary"
                app:trackColor="?colorSurfaceVariant"
                app:trackCornerRadius="4dp"
                app:trackThickness="6dp"
                app:layout_constraintEnd_toStartOf="@+id/ip_more"
                app:layout_constraintStart_toEndOf="@+id/iv_thumbnail"
                app:layout_constraintTop_toBottomOf="@+id/tv_progress"
                tools:progress="40" />

            <!-- Info / log line -->
            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/info_line"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:ellipsize="end"
                android:maxLines="2"
                android:text="@{progressInfo.infoLine}"
                android:textAppearance="?textAppearanceLabelSmall"
                android:textColor="?colorOnSurfaceVariant"
                android:fontFamily="monospace"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/iv_thumbnail"
                tools:text="[download] 40% of 48MB at 512KiB/s ETA 01:23" />

            <!-- More button (icon only, top-right) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/ip_more"
                style="?attr/materialIconButtonStyle"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:onClick="@{(view) -> progressListener.onMenuClicked(view, downloadId, isRegular)}"
                app:icon="@drawable/ic_more_24dp"
                app:iconTint="?colorOnSurfaceVariant"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>
</layout>
