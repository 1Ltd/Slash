<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>
        <import type="android.view.View" />
        <variable name="viewModel" type="com.myAllVideoBrowser.ui.main.video.VideoViewModel" />
        <variable name="mainViewModel" type="com.myAllVideoBrowser.ui.main.home.MainViewModel" />
    </data>

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="?android:attr/colorBackground">

        <com.google.android.material.appbar.AppBarLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="?colorSurface"
            app:elevation="0dp"
            app:liftOnScroll="true"
            app:liftOnScrollTargetViewId="@+id/rv_video">

            <com.google.android.material.appbar.MaterialToolbar
                android:id="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                app:titleCentered="true"
                app:title="@string/title_video"
                app:titleTextAppearance="?textAppearanceTitleLarge" />
        </com.google.android.material.appbar.AppBarLayout>

        <!-- Empty state -->
        <LinearLayout
            android:id="@+id/layout_empty"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="32dp"
            android:visibility="@{viewModel.localVideos.size() == 0 ? View.VISIBLE : View.GONE}"
            app:layout_behavior="@string/appbar_scrolling_view_behavior">

            <com.google.android.material.imageview.ShapeableImageView
                android:layout_width="96dp"
                android:layout_height="96dp"
                android:src="@drawable/ic_empty"
                android:scaleType="fitCenter"
                android:layout_marginBottom="20dp"
                app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.Rounded" />

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/tv_empty_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/video_empty_message"
                android:textAppearance="?textAppearanceBodyLarge"
                android:textColor="?colorOnSurfaceVariant"
                android:gravity="center" />
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_video"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingTop="8dp"
            android:paddingBottom="16dp"
            app:items="@{viewModel.localVideos}"
            app:layout_behavior="@string/appbar_scrolling_view_behavior" />

        <FrameLayout
            android:id="@+id/anchor"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />
    </androidx.coordinatorlayout.widget.CoordinatorLayout>
</layout>
