<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>
        <import type="android.view.View" />
        <variable name="localVideo" type="com.myAllVideoBrowser.data.local.model.LocalVideo" />
        <variable name="videoListener" type="com.myAllVideoBrowser.ui.component.adapter.VideoListener" />
    </data>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_video"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginVertical="6dp"
        android:clickable="true"
        android:focusable="true"
        android:onClick="@{() -> videoListener.onItemClicked(localVideo)}"
        app:cardCornerRadius="16dp"
        app:cardElevation="2dp"
        app:strokeWidth="0dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="12dp">

            <!-- 16:9 thumbnail with rounded corners -->
            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/iv_thumbnail"
                android:layout_width="100dp"
                android:layout_height="60dp"
                android:scaleType="centerCrop"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:shapeAppearanceOverlay="@style/customImageViewRounded" />

            <!-- File name -->
            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/tv_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:ellipsize="end"
                android:maxLines="2"
                android:text="@{localVideo.name}"
                android:textAppearance="?textAppearanceTitleSmall"
                app:layout_constraintEnd_toStartOf="@+id/iv_more"
                app:layout_constraintStart_toEndOf="@+id/iv_thumbnail"
                app:layout_constraintTop_toTopOf="parent"
                tools:text="awesome_video.mp4" />

            <!-- File size -->
            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/tv_size"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_marginTop="4dp"
                android:text="@{localVideo.size}"
                android:textAppearance="?textAppearanceBodySmall"
                android:textColor="?colorOnSurfaceVariant"
                app:layout_constraintEnd_toStartOf="@+id/iv_more"
                app:layout_constraintStart_toEndOf="@+id/iv_thumbnail"
                app:layout_constraintTop_toBottomOf="@+id/tv_name"
                tools:text="128 MB" />

            <!-- More menu -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/iv_more"
                style="?attr/materialIconButtonStyle"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:onClick="@{(view) -> videoListener.onMenuClicked(view, localVideo)}"
                app:icon="@drawable/ic_more_24dp"
                app:iconTint="?colorOnSurfaceVariant"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>
</layout>
